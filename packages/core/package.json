{
  "name": "@clawcart/core",
  "version": "0.1.0",
  "description": "Core ClawCart SDK - cart building, price optimization, retailer adapters",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "playwright": "^1.41.0"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "shopping",
    "cart",
    "ecommerce",
    "ai",
    "agent",
    "openclaw"
  ],
  "author": "EVM Systems",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evmsystems-ai/clawcart.git",
    "directory": "packages/core"
  }
}
