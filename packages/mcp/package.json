{
  "name": "@clawcart/mcp",
  "version": "0.1.0",
  "description": "ClawCart MCP server",
  "main": "dist/index.js",
  "bin": {
    "clawcart-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs --dts",
    "dev": "tsup src/index.ts src/cli.ts --format cjs --dts --watch",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@clawcart/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^0.5.0"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "vitest": "^1.2.0"
  },
  "keywords": ["mcp", "shopping", "cart", "ai"],
  "author": "EVM Systems",
  "license": "MIT"
}
