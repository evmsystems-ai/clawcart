<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ClawCart — Cross-Store Cart Sharing for AI Agents</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        code, pre { font-family: 'JetBrains Mono', monospace; }
        .gradient-text {
            background: linear-gradient(135deg, #f97316 0%, #ea580c 50%, #c2410c 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .gradient-bg {
            background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
        }
        .code-block {
            background: #1e1e1e;
            border-radius: 12px;
        }
    </style>
</head>
<body class="bg-white text-gray-900">
    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 bg-white/80 backdrop-blur-md border-b border-gray-100 z-50">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="text-xl sm:text-2xl">🛒</span>
                <span class="font-bold text-lg sm:text-xl">ClawCart</span>
            </div>
            <!-- Desktop Nav -->
            <div class="hidden md:flex items-center gap-6">
                <a href="#features" class="text-gray-600 hover:text-gray-900 text-sm">Features</a>
                <a href="#how-it-works" class="text-gray-600 hover:text-gray-900 text-sm">How it Works</a>
                <a href="#recipes" class="text-gray-600 hover:text-gray-900 text-sm">Recipes</a>
                <a href="https://github.com/evm-systems/clawcart" class="bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 transition text-sm">Get Started</a>
            </div>
            <!-- Mobile Menu Button -->
            <button onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" class="md:hidden p-2 -mr-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
            <div class="px-4 py-3 space-y-3">
                <a href="#features" class="block text-gray-600 hover:text-gray-900">Features</a>
                <a href="#how-it-works" class="block text-gray-600 hover:text-gray-900">How it Works</a>
                <a href="#recipes" class="block text-gray-600 hover:text-gray-900">Recipes</a>
                <a href="https://github.com/evm-systems/clawcart" class="block bg-orange-500 text-white px-4 py-2 rounded-lg text-center hover:bg-orange-600 transition">Get Started</a>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <section class="gradient-bg pt-24 sm:pt-32 pb-12 sm:pb-20">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
            <h1 class="text-3xl sm:text-5xl md:text-6xl font-bold mb-4 sm:mb-6">
                <span class="gradient-text">Give Your Agent a Shopping Cart</span>
            </h1>
            <p class="text-base sm:text-xl text-gray-600 mb-6 sm:mb-8 max-w-2xl mx-auto">
                The only way to share carts across 200+ retailers. Build agents that shop on Amazon, Walmart, Target — and share carts with humans or other agents.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
                <a href="#install" class="bg-orange-500 text-white px-6 py-3 rounded-lg font-medium hover:bg-orange-600 transition flex items-center justify-center gap-2">
                    <span>Install Now</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>
                <a href="https://github.com/evm-systems/clawcart" class="border border-gray-300 px-6 py-3 rounded-lg font-medium hover:border-gray-400 transition text-center">
                    View on GitHub
                </a>
            </div>
            
            <!-- Install Command -->
            <div class="mt-12 code-block p-4 text-left max-w-lg mx-auto" id="install">
                <div class="flex items-center gap-2 text-gray-400 text-sm mb-2">
                    <span class="w-3 h-3 rounded-full bg-red-500"></span>
                    <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
                    <span class="w-3 h-3 rounded-full bg-green-500"></span>
                    <span class="ml-2">Terminal</span>
                </div>
                <code class="text-green-400">$ openclaw skills install clawcart</code>
            </div>
        </div>
    </section>

    <!-- Powered by Share-a-Cart -->
    <section class="py-8 sm:py-12 border-b border-gray-100 bg-gray-50">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
            <p class="text-gray-500 mb-4 text-sm">Powered by</p>
            <a href="https://share-a-cart.com" target="_blank" class="inline-flex items-center gap-3 hover:opacity-80 transition">
                <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center">
                    <span class="text-white text-xl sm:text-2xl">🛒</span>
                </div>
                <span class="text-xl sm:text-2xl font-bold text-gray-800">Share-a-Cart</span>
            </a>
            <p class="text-gray-400 text-xs mt-2">Instantly share shopping carts from 200+ retailers</p>
        </div>
    </section>

    <!-- Supported Retailers -->
    <section class="py-10 sm:py-16 border-b border-gray-100">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
            <h3 class="text-center text-gray-600 font-medium mb-6 sm:mb-8">Works with 200+ retailers</h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-8 items-center justify-items-center">
                <!-- Using brand.dev CDN for reliable logos -->
                <img src="https://cdn.brandfetch.io/amazon.com/w/512/h/512/logo" alt="Amazon" class="h-8 sm:h-10 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/walmart.com/w/512/h/512/logo" alt="Walmart" class="h-8 sm:h-10 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/target.com/w/512/h/512/logo" alt="Target" class="h-8 sm:h-10 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/costco.com/w/512/h/512/logo" alt="Costco" class="h-8 sm:h-10 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/instacart.com/w/512/h/512/logo" alt="Instacart" class="h-6 sm:h-8 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/kroger.com/w/512/h/512/logo" alt="Kroger" class="h-8 sm:h-10 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/bestbuy.com/w/512/h/512/logo" alt="Best Buy" class="h-6 sm:h-8 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/homedepot.com/w/512/h/512/logo" alt="Home Depot" class="h-8 sm:h-10 w-auto object-contain" loading="lazy">
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-8 items-center justify-items-center mt-6 opacity-70">
                <img src="https://cdn.brandfetch.io/lowes.com/w/512/h/512/logo" alt="Lowe's" class="h-6 sm:h-8 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/walgreens.com/w/512/h/512/logo" alt="Walgreens" class="h-6 sm:h-8 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/cvs.com/w/512/h/512/logo" alt="CVS" class="h-6 sm:h-8 w-auto object-contain" loading="lazy">
                <img src="https://cdn.brandfetch.io/samsclub.com/w/512/h/512/logo" alt="Sam's Club" class="h-6 sm:h-8 w-auto object-contain" loading="lazy">
            </div>
            <p class="text-center text-gray-400 text-sm mt-8">
                <a href="https://share-a-cart.com/supported" target="_blank" class="hover:text-orange-500 transition">+ 200 more retailers →</a>
            </p>
        </div>
    </section>

    <!-- Features -->
    <section class="py-20" id="features">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-3xl font-bold text-center mb-4">Everything your agent needs to shop</h2>
            <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">ClawCart turns your OpenClaw assistant into a shopping expert. From groceries to office supplies, your agent handles the cart — you just approve.</p>
            
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Feature 1 -->
                <div class="p-6 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-lg transition">
                    <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-2xl">🛍️</span>
                    </div>
                    <h3 class="font-semibold text-lg mb-2">Multi-Retailer Carts</h3>
                    <p class="text-gray-600">Build carts on Amazon, Walmart, Target, Instacart, and 200+ retailers. One interface, endless stores.</p>
                </div>
                
                <!-- Feature 2 -->
                <div class="p-6 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-lg transition">
                    <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-2xl">🔗</span>
                    </div>
                    <h3 class="font-semibold text-lg mb-2">Shareable Cart Links</h3>
                    <p class="text-gray-600">Your agent creates a cart and sends you a link. Review items, approve, and checkout with one click.</p>
                </div>
                
                <!-- Feature 3 -->
                <div class="p-6 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-lg transition">
                    <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-2xl">🧠</span>
                    </div>
                    <h3 class="font-semibold text-lg mb-2">AI Context Extraction</h3>
                    <p class="text-gray-600">"Get ingredients for tacos for 6 people" — your agent figures out exactly what to buy.</p>
                </div>
                
                <!-- Feature 4 -->
                <div class="p-6 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-lg transition">
                    <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-2xl">📋</span>
                    </div>
                    <h3 class="font-semibold text-lg mb-2">Reusable Recipes</h3>
                    <p class="text-gray-600">Save your weekly groceries as a recipe. Your agent can reorder with one command.</p>
                </div>
                
                <!-- Feature 5 -->
                <div class="p-6 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-lg transition">
                    <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-2xl">✅</span>
                    </div>
                    <h3 class="font-semibold text-lg mb-2">Human-in-the-Loop</h3>
                    <p class="text-gray-600">Nothing gets ordered without your approval. Your agent shops, you decide.</p>
                </div>
                
                <!-- Feature 6 -->
                <div class="p-6 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-lg transition">
                    <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
                        <span class="text-2xl">🔄</span>
                    </div>
                    <h3 class="font-semibold text-lg mb-2">Recurring Orders</h3>
                    <p class="text-gray-600">Set up weekly groceries, monthly supplies, or quarterly restocks. Your agent handles the schedule.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- How it Works -->
    <section class="py-20 bg-gray-50" id="how-it-works">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-3xl font-bold text-center mb-4">How it works</h2>
            <p class="text-gray-600 text-center mb-12">Three steps to agent-powered shopping</p>
            
            <div class="grid md:grid-cols-3 gap-8 mb-16">
                <div class="text-center">
                    <div class="w-16 h-16 bg-orange-500 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-bold">1</div>
                    <h3 class="font-semibold text-lg mb-2">Agent Builds Cart</h3>
                    <p class="text-gray-600">Your agent searches products on Amazon, Walmart, Target, or any of 200+ retailers</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-orange-500 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-bold">2</div>
                    <h3 class="font-semibold text-lg mb-2">Generate Share Link</h3>
                    <p class="text-gray-600">One API call creates a shareable cart link that works across devices and accounts</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-orange-500 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-bold">3</div>
                    <h3 class="font-semibold text-lg mb-2">Share & Checkout</h3>
                    <p class="text-gray-600">Send to humans for approval, or pass to another agent. Recipient imports cart and buys.</p>
                </div>
            </div>
            
            <!-- Use Case Examples -->
            <p class="text-center text-gray-500 text-sm mb-6">Developers are using ClawCart for:</p>
            <div class="grid md:grid-cols-4 gap-4">
                <div class="bg-white p-4 rounded-xl border border-gray-200 text-center">
                    <span class="text-xl mb-2 block">🤖</span>
                    <p class="text-sm text-gray-600">Agent-to-agent cart handoffs</p>
                </div>
                <div class="bg-white p-4 rounded-xl border border-gray-200 text-center">
                    <span class="text-xl mb-2 block">🎒</span>
                    <p class="text-sm text-gray-600">School supply automation</p>
                </div>
                <div class="bg-white p-4 rounded-xl border border-gray-200 text-center">
                    <span class="text-xl mb-2 block">🏢</span>
                    <p class="text-sm text-gray-600">Business procurement bots</p>
                </div>
                <div class="bg-white p-4 rounded-xl border border-gray-200 text-center">
                    <span class="text-xl mb-2 block">💝</span>
                    <p class="text-sm text-gray-600">Nonprofit wishlist agents</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Code Example -->
    <section class="py-20">
        <div class="max-w-4xl mx-auto px-6">
            <h2 class="text-3xl font-bold text-center mb-4">Simple API</h2>
            <p class="text-gray-600 text-center mb-12">Just a few lines to create a shareable cart</p>
            
            <div class="code-block p-6 overflow-x-auto">
                <pre class="text-sm"><code class="text-gray-300"><span class="text-purple-400">import</span> { ClawCart } <span class="text-purple-400">from</span> <span class="text-green-400">'@openclaw/clawcart'</span>;

<span class="text-gray-500">// Create a cart</span>
<span class="text-purple-400">const</span> cart = <span class="text-purple-400">new</span> <span class="text-yellow-400">ClawCart</span>({ <span class="text-blue-400">retailer</span>: <span class="text-green-400">'amazon'</span> });

<span class="text-gray-500">// Add items by search</span>
<span class="text-purple-400">await</span> cart.<span class="text-yellow-400">addItem</span>({
  <span class="text-blue-400">query</span>: <span class="text-green-400">"Organic whole milk 1 gallon"</span>,
  <span class="text-blue-400">quantity</span>: <span class="text-orange-400">2</span>
});

<span class="text-gray-500">// Or by product ID</span>
<span class="text-purple-400">await</span> cart.<span class="text-yellow-400">addItem</span>({ <span class="text-blue-400">asin</span>: <span class="text-green-400">"B08N5WRWNW"</span>, <span class="text-blue-400">quantity</span>: <span class="text-orange-400">1</span> });

<span class="text-gray-500">// Generate shareable link</span>
<span class="text-purple-400">const</span> shareUrl = <span class="text-purple-400">await</span> cart.<span class="text-yellow-400">share</span>();
<span class="text-gray-500">// → "https://share-a-cart.com/c/abc123"</span>

<span class="text-gray-500">// Send to human for approval</span>
<span class="text-purple-400">await</span> <span class="text-yellow-400">notify</span>(<span class="text-green-400">`Your cart is ready: </span><span class="text-orange-400">${shareUrl}</span><span class="text-green-400">`</span>);</code></pre>
            </div>
        </div>
    </section>

    <!-- Recipes Section -->
    <section class="py-20 bg-gray-50" id="recipes">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-3xl font-bold text-center mb-4">Pre-built Cart Templates</h2>
            <p class="text-gray-600 text-center mb-12">Start with templates or build your own. Your agent can use these out of the box.</p>
            
            <div class="grid md:grid-cols-4 gap-6">
                <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-lg transition cursor-pointer">
                    <span class="text-3xl mb-3 block">🥛</span>
                    <h3 class="font-semibold mb-1">Weekly Groceries</h3>
                    <p class="text-sm text-gray-500">Milk, eggs, bread, produce</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-lg transition cursor-pointer">
                    <span class="text-3xl mb-3 block">🏢</span>
                    <h3 class="font-semibold mb-1">Office Supplies</h3>
                    <p class="text-sm text-gray-500">Paper, pens, sticky notes</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-lg transition cursor-pointer">
                    <span class="text-3xl mb-3 block">🎒</span>
                    <h3 class="font-semibold mb-1">School Supplies</h3>
                    <p class="text-sm text-gray-500">Pencils, folders, backpack</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-lg transition cursor-pointer">
                    <span class="text-3xl mb-3 block">🧴</span>
                    <h3 class="font-semibold mb-1">Hygiene Kit</h3>
                    <p class="text-sm text-gray-500">Soap, toothbrush, essentials</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-lg transition cursor-pointer">
                    <span class="text-3xl mb-3 block">🎉</span>
                    <h3 class="font-semibold mb-1">Party Supplies</h3>
                    <p class="text-sm text-gray-500">Plates, cups, decorations</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-lg transition cursor-pointer">
                    <span class="text-3xl mb-3 block">🐕</span>
                    <h3 class="font-semibold mb-1">Pet Supplies</h3>
                    <p class="text-sm text-gray-500">Food, treats, toys</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-lg transition cursor-pointer">
                    <span class="text-3xl mb-3 block">💻</span>
                    <h3 class="font-semibold mb-1">Home Office</h3>
                    <p class="text-sm text-gray-500">Monitor, keyboard, desk lamp</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-lg transition cursor-pointer">
                    <span class="text-3xl mb-3 block">☕</span>
                    <h3 class="font-semibold mb-1">Break Room</h3>
                    <p class="text-sm text-gray-500">Coffee, snacks, cups</p>
                </div>
            </div>
            
            <div class="text-center mt-8">
                <a href="#" class="text-orange-500 hover:text-orange-600 font-medium">Browse all templates →</a>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-3xl font-bold mb-4">Ready to let your agent shop?</h2>
            <p class="text-gray-600 mb-8">Install ClawCart and start creating carts in minutes.</p>
            
            <div class="code-block p-4 max-w-md mx-auto mb-8">
                <code class="text-green-400">$ openclaw skills install clawcart</code>
            </div>
            
            <div class="flex justify-center gap-4">
                <a href="https://docs.openclaw.ai/skills/clawcart" class="bg-orange-500 text-white px-6 py-3 rounded-lg font-medium hover:bg-orange-600 transition">
                    Read the Docs
                </a>
                <a href="https://github.com/evm-systems/clawcart" class="border border-gray-300 px-6 py-3 rounded-lg font-medium hover:border-gray-400 transition">
                    GitHub
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-gray-100 py-12">
        <div class="max-w-6xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-2">
                    <span class="text-xl">🛒</span>
                    <span class="font-bold">ClawCart</span>
                    <span class="text-gray-400">by EVM Systems</span>
                </div>
                <div class="flex gap-6 text-gray-600">
                    <a href="https://github.com/evm-systems/clawcart" class="hover:text-gray-900">GitHub</a>
                    <a href="https://discord.gg/openclaw" class="hover:text-gray-900">Discord</a>
                    <a href="https://twitter.com/evmsystems" class="hover:text-gray-900">Twitter</a>
                </div>
            </div>
            <p class="text-center text-gray-400 text-sm mt-8">
                Powered by <a href="https://share-a-cart.com" class="text-orange-500 hover:underline">Share-a-Cart</a> • Built for <a href="https://openclaw.ai" class="text-orange-500 hover:underline">OpenClaw</a>
            </p>
        </div>
    </footer>
</body>
</html>
